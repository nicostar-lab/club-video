<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="626.0" prefWidth="846.0" style="-fx-background-color:  #1b263b;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AbonneController">
    <left>
        <fx:include fx:id="navBar" source="NavBar.fxml" />
    </left>
    <center>
        <AnchorPane style="-fx-background-color:  #1b263b;" BorderPane.alignment="CENTER">
            <children>
                <Label layoutX="20.0" layoutY="15.0" text="Gestion des Abonnés" textFill="WHITE">
                    <font>
                        <Font name="Leelawadee UI Bold" size="24.0" />
                    </font>
                </Label>
                
                <!-- Formulaire -->
                <VBox layoutX="20.0" layoutY="60.0" prefWidth="620.0" spacing="10.0">
                    <HBox spacing="10.0">
                        <TextField fx:id="txtNomAbonne" promptText="Nom" prefWidth="200.0" style="-fx-background-color: white;"/>
                        <TextField fx:id="txtAdresseAbonne" promptText="Adresse" prefWidth="250.0" style="-fx-background-color: white;"/>
                    </HBox>
                    <HBox spacing="10.0">
                        <Button text="Ajouter" onAction="#ajouterAbonne" style="-fx-background-color: #C00707; -fx-text-fill: white;" prefWidth="100.0"/>
                        <Button text="Modifier" onAction="#modifierAbonne" style="-fx-background-color: #C00707; -fx-text-fill: white;" prefWidth="100.0"/>
                        <Button text="Supprimer" onAction="#supprimerAbonne" style="-fx-background-color: black; -fx-text-fill: white;" prefWidth="100.0"/>
                        <Button text="Actualiser" onAction="#actualiserTable" style="-fx-background-color: #C00707; -fx-text-fill: white;" prefWidth="100.0"/>
                        <Button text="Vider" onAction="#viderChamps" style="-fx-background-color: gray; -fx-text-fill: white;" prefWidth="100.0"/>
                    </HBox>
                </VBox>
                
                <!-- TableView -->
                <TableView fx:id="tableAbonnes" layoutX="20.0" layoutY="170.0" prefWidth="620.0" prefHeight="430.0" style="-fx-background-color: white;">
                    <columns>
                        <TableColumn fx:id="colNumAbonne" text="N°" prefWidth="50.0" />
                        <TableColumn fx:id="colNomAbonne" text="Nom" prefWidth="150.0" />
                        <TableColumn fx:id="colAdresseAbonne" text="Adresse" prefWidth="150.0" />
                        <TableColumn fx:id="colDateAbonnement" text="Date Abonnement" prefWidth="120.0" />
                        <TableColumn fx:id="colDateEntree" text="Date Entrée" prefWidth="120.0" />
                        <TableColumn fx:id="colNombreLocation" text="Nb Locations" prefWidth="100.0" />
                    </columns>
                </TableView>
            </children>
        </AnchorPane>
    </center>
</BorderPane>
