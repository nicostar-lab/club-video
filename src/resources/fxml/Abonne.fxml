<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="724.0" prefWidth="882.0" style="-fx-background-color:  #1b263b;" stylesheets="@../styles/action-buttons.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AbonneController">
    <left>
        <fx:include fx:id="navBar" source="NavBar.fxml" />
    </left>
    <center>
        <AnchorPane style="-fx-background-color:  #1b263b;" BorderPane.alignment="CENTER">
            <children>
                <Label layoutX="20.0" layoutY="15.0" text="Gestion des Abonnés" textFill="WHITE">
                    <font>
                        <Font name="Leelawadee UI Bold" size="24.0" />
                    </font>
                </Label>
                
                <!-- Formulaire -->
                <VBox layoutX="20.0" layoutY="84.0" prefHeight="103.0" prefWidth="619.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" spacing="10.0" style="-fx-background-color: rgba(13, 27, 42, 0.92); -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: rgba(255, 255, 255, 0.10);">
                    <HBox prefHeight="36.0" prefWidth="567.0" spacing="10.0">
                        <TextField fx:id="txtNomAbonne" prefWidth="200.0" promptText="Nom" style="-fx-background-color: white;" />
                        <TextField fx:id="txtAdresseAbonne" prefWidth="250.0" promptText="Adresse" style="-fx-background-color: white;" />
                    </HBox>
                    <HBox alignment="CENTER_LEFT" prefHeight="46.0" prefWidth="518.0" spacing="10.0">
                        <Button onAction="#ajouterAbonne" prefWidth="100.0" styleClass="form-btn,form-btn-primary" text="Ajouter" />
                        <Button onAction="#modifierAbonne" prefWidth="100.0" styleClass="form-btn,form-btn-primary" text="Modifier" />
                        <Button onAction="#supprimerAbonne" prefWidth="100.0" styleClass="form-btn,form-btn-danger" text="Supprimer" />
                        <Button onAction="#actualiserTable" prefWidth="100.0" styleClass="form-btn,form-btn-primary" text="Actualiser" />
                        <Button onAction="#viderChamps" prefWidth="100.0" styleClass="form-btn,form-btn-muted" text="Vider" />
                    </HBox>
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
                </VBox>
                
                <!-- TableView -->
                <TableView fx:id="tableAbonnes" layoutX="20.0" layoutY="205.0" prefHeight="430.0" prefWidth="620.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="205.0" AnchorPane.bottomAnchor="20.0" styleClass="data-table">
                    <columns>
                        <TableColumn fx:id="colNumAbonne" prefWidth="50.0" text="N°" />
                        <TableColumn fx:id="colNomAbonne" prefWidth="150.0" text="Nom" />
                        <TableColumn fx:id="colAdresseAbonne" prefWidth="150.0" text="Adresse" />
                        <TableColumn fx:id="colDateAbonnement" prefWidth="120.0" text="Date Abonnement" />
                        <TableColumn fx:id="colDateEntree" prefWidth="120.0" text="Date Entrée" />
                        <TableColumn fx:id="colNombreLocation" prefWidth="100.0" text="Nb Locations" />
                    </columns>
                </TableView>
            </children>
        </AnchorPane>
    </center>
</BorderPane>
